typedef struct my_s {
  union my_nested_u {
    char c;
    struct my_nested_s {
      int i;
    } n;
    int i;
  } n;
  unsigned u;
} my_t;

---

cdef extern from "nested.test":

    cdef union my_nested_u

    cdef struct my_s:
        my_nested_u n
        unsigned int u

    ctypedef my_s my_t
